{
  "name": "inventory-management",
  "version": "1.3.4",
  "description": "本地化仓库管理系统",
  "main": ".vite/build/main/index.js",
  "scripts": {
    "start": "node scripts/electron-only.js",
    "dev": "node scripts/dev-server.js",
    "clean": "node scripts/clean-release.js",
    "clean:all": "node -e \"const fs = require('fs'); ['release', 'dist', '.vite/build'].forEach(dir => { try { fs.rmSync(dir, {recursive: true, force: true}); } catch(e) {} })\"",
    "build:code": "vite build --config vite.main.config.ts && vite build --config vite.preload.config.ts && vite build --config vite.config.ts",
    "build:updater": "vite build --config vite.updater.config.ts",
    "build:main:watch": "vite build --config vite.main.config.ts --watch",
    "build:preload:watch": "vite build --config vite.preload.config.ts --watch",
    "build:renderer:watch": "vite build --config vite.config.ts --watch",
    "prebuild": "npm run rebuild",
    "build": "npm run build:code && electron-builder --win nsis",
    "build:dir": "npm run build:code && electron-builder --dir",
    "build:installer": "npm run build:code && electron-builder --win nsis",
    "build:portable": "npm run build:code && electron-builder --win dir",
    "build:all": "npm run build:code && electron-builder --win nsis --win dir",
    "package": "npm run build:code && electron-builder --dir",
    "make": "npm run build:code && electron-builder --win nsis",
    "publish": "electron-builder --publish=never",
    "lint": "eslint --ext .ts .",
    "typecheck": "tsc --noEmit",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "install:safe": "node scripts/install-without-build.js",
    "install:better-sqlite3": "node scripts/install-better-sqlite3.js",
    "install:better-sqlite3:enhanced": "node scripts/install-better-sqlite3-enhanced.js",
    "install:bindings": "node scripts/install-bindings.js",
    "rebuild:sqlite": "node scripts/rebuild-sqlite.js",
    "fix:sqlite": "node scripts/fix-better-sqlite3.js",
    "install:sqlite:prebuilt": "node scripts/install-sqlite-prebuilt.js",
    "update:server": "node scripts/update-server.js",
    "update:server:prod": "NODE_ENV=production PORT=8080 node scripts/update-server.js",
    "download:node-runtime": "node scripts/download-node-runtime.js"
  },
  "keywords": [
    "inventory",
    "management",
    "electron",
    "sqlite"
  ],
  "author": "Your Company",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-deb": "^7.4.0",
    "@electron-forge/maker-rpm": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/maker-zip": "^7.4.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.4.0",
    "@electron-forge/plugin-fuses": "^7.4.0",
    "@electron-forge/plugin-vite": "^7.4.0",
    "@electron-forge/shared-types": "^7.4.0",
    "@electron/fuses": "^1.8.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitejs/plugin-react": "^4.2.0",
    "archiver": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "electron-rebuild": "^3.2.9",
    "eslint": "^8.54.0",
    "eslint-plugin-import": "^2.29.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^9.0.3"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.0",
    "@reduxjs/toolkit": "^1.9.7",
    "adm-zip": "^0.5.10",
    "antd": "^5.12.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.6.0",
    "cors": "^2.8.5",
    "echarts": "^5.4.3",
    "echarts-for-react": "^3.0.2",
    "electron-squirrel-startup": "^1.0.0",
    "electron-updater": "^6.6.2",
    "express": "^4.18.2",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-redux": "^8.1.3",
    "react-router-dom": "^6.20.0",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.company.inventory",
    "productName": "仓库管理系统",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "generic",
      "url": "http://111.228.2.193:8080/updates/"
    },
    "releaseInfo": {
      "releaseNotes": "版本更新内容将在这里显示\n\n✨ 新增功能：\n- 功能1\n- 功能2\n\n🐛 问题修复：\n- 修复问题1\n- 修复问题2\n\n🔧 性能优化：\n- 优化项1"
    },
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "files": [
      "dist/**/*",
      ".vite/build/**/*",
      "scripts/**/*",
      "node_modules/**/*",
      "package.json",
      "!node_modules/**/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!node_modules/**/{test,__tests__,tests,powered-test,example,examples}",
      "!node_modules/**/*.d.ts",
      "!node_modules/**/*.map"
    ],
    "asarUnpack": [
      "**/*.node",
      "**/node_modules/better-sqlite3/**",
      "**/node_modules/bindings/**",
      "**/node_modules/file-uri-to-path/**",
      "**/node_modules/adm-zip/**",
      "**/better-sqlite3/**/node_modules/bindings/**"
    ],
    "extraResources": [
      {
        "from": "database",
        "to": "database"
      },
      {
        "from": "scripts",
        "to": "scripts"
      },
      {
        "from": "node-runtime",
        "to": "node-runtime"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "sign": false,
      "signingHashAlgorithms": [],
      "verifyUpdateCodeSignature": false
    },
    "electronDownload": {
      "cache": "${CACHE}/electron",
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "仓库管理系统",
      "deleteAppDataOnUninstall": false,
      "differentialPackage": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}
